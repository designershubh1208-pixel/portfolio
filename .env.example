# Copy this file to `.env` and fill in your Firebase web app config.
# Firebase Console → Project settings → Your apps → Web app
# NEVER put real keys in this file — it is committed to Git.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: server-side Firebase Admin (backup if VITE_* is not set)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: inbox API secret
# ADMIN_SECRET=your-long-random-secret
